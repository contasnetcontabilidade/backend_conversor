# Chave da API Gemini (obrigatoria para o resumo)
GEMINI_API_KEY=

# Porta do backend
PORT=3000

# Caminho padrao de audio (relativo a pasta backend)
DEFAULT_AUDIO_FILE=audio_reuniao.WAV

# Modelo padrao do Whisper
WHISPER_MODEL=base

# Provider de transcricao: whisper | gemini
TRANSCRICAO_PROVIDER=

# Modelo padrao do Gemini para transcricao de audio
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash

# Modelos fallback separados por virgula (tentados quando houver indisponibilidade)
GEMINI_TRANSCRIPTION_FALLBACK_MODELS=gemini-2.5-flash-lite

# Retries para indisponibilidade temporaria da Gemini
GEMINI_TRANSCRIPTION_RETRY_ATTEMPTS=4
GEMINI_TRANSCRIPTION_RETRY_BASE_DELAY_MS=800

# Modelo padrao do Gemini
GEMINI_MODEL=gemini-2.5-flash

# Pasta de uploads (relativa a pasta backend)
UPLOAD_DIR=uploads
